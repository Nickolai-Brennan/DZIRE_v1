# Environment Variables — DZIRE_v1
# Copy this file to .env and fill in the values.

# ── App ──────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_KEY

# ── JWT Auth ─────────────────────────────────────────
JWT_SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_JWT_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database (MotherDuck / PostgreSQL) ───────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dzire_v1
MOTHERDUCK_TOKEN=

# ── Backend (FastAPI) ─────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Frontend (Vite) ───────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── Hosting ───────────────────────────────────────────
# Frontend → Vercel
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# Backend → Render
RENDER_SERVICE_ID=
RENDER_API_KEY=
