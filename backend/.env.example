# DZIRE_v1 backend — environment variables
# Copy to .env and fill in values before running

# Environment: "development" or "production"
ENV=development

# PostgreSQL connection URL
# Example: postgresql+asyncpg://user:password@localhost:5432/dzire
DATABASE_URL=postgresql+asyncpg://dzire:dzire@localhost:5432/dzire

# JWT
JWT_SECRET=change-me-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173

# Seed dev admin (only takes effect when ENV=development)
# TODO: Change admin credentials before production.
SEED_DEV_ADMIN=true
