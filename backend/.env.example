# DZIRE_v1 backend — environment variables
# Copy to .env and fill in values before running

# Environment: "development" or "production"
ENV=development

# PostgreSQL connection URL
# Example: postgresql+asyncpg://user:password@localhost:5432/dzire
DATABASE_URL=postgresql+asyncpg://dzire:dzire@localhost:5432/dzire

# JWT
JWT_SECRET=change-me-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5174, http://localhost:5173

# Seed dev admin (only takes effect when ENV=development)
# TODO: Change admin credentials before production.
SEED_DEV_ADMIN=true

# Frontend URL (used for Stripe redirect URLs)
FRONTEND_URL=http://localhost:5173

# Stripe (test mode) — get from https://dashboard.stripe.com/test/apikeys
# Replace sk_test_... and pk_test_... with your actual test keys.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Stripe webhook secret — obtain from `stripe listen --forward-to localhost:8000/api/payments/webhook`
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Stripe Price IDs for VIP plans (create in Stripe dashboard or via CLI)
STRIPE_PRICE_ID_VIP_MONTHLY=price_replace_me_monthly
STRIPE_PRICE_ID_VIP_YEARLY=price_replace_me_yearly
